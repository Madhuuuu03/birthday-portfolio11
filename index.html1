<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Happy Birthday ❤️</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&family=Pacifico&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
scroll-behavior:smooth;
}

body{
background:linear-gradient(135deg,#FFE5EC,#FDE2E4,#E2F0CB,#CDE7FF);
overflow-x:hidden;
color:#444;
}

/* Floating Background */

.background span{
position:absolute;
font-size:45px;
animation:float 10s linear infinite;
opacity:.8;
}

.background span:nth-child(1){left:5%;animation-duration:12s;}
.background span:nth-child(2){left:18%;animation-duration:8s;}
.background span:nth-child(3){left:35%;animation-duration:14s;}
.background span:nth-child(4){left:55%;animation-duration:10s;}
.background span:nth-child(5){left:75%;animation-duration:13s;}
.background span:nth-child(6){left:90%;animation-duration:9s;}

@keyframes float{
0%{
transform:translateY(100vh) rotate(0deg);
}
100%{
transform:translateY(-120vh) rotate(360deg);
}
}

/* Hero */

.hero{
height:100vh;
display:flex;
align-items:center;
justify-content:center;
padding:40px;
}

.glass{
background:rgba(255,255,255,.35);
backdrop-filter:blur(18px);
padding:50px;
border-radius:30px;
box-shadow:0 15px 40px rgba(0,0,0,.15);
text-align:center;
animation:fadeUp 1.3s;
max-width:700px;
}

@keyframes fadeUp{
from{
opacity:0;
transform:translateY(80px);
}
to{
opacity:1;
transform:translateY(0);
}
}

.hero h1{
font-family:'Pacifico',cursive;
font-size:65px;
color:#ff5f87;
margin-bottom:15px;
}

.hero h2{
font-size:30px;
margin-bottom:20px;
}

.hero p{
font-size:18px;
line-height:1.8;
margin-bottom:30px;
}

button{
padding:16px 35px;
border:none;
background:#ff7aa2;
color:white;
font-size:18px;
border-radius:50px;
cursor:pointer;
transition:.4s;
box-shadow:0 8px 20px rgba(255,122,162,.4);
}

button:hover{
transform:scale(1.08);
background:#ff4f81;
}

/* Sections */

section{
padding:90px 10%;
}

.title{
text-align:center;
font-size:40px;
color:#ff5d8f;
margin-bottom:50px;
font-family:'Pacifico';
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:30px;
}

.card{
background:white;
padding:30px;
border-radius:25px;
box-shadow:0 15px 35px rgba(0,0,0,.1);
transition:.4s;
text-align:center;
}

.card:hover{
transform:translateY(-10px);
}

.card h3{
font-size:24px;
margin:15px 0;
}

.card p{
line-height:1.7;
}

.icon{
font-size:55px;
}

/* Timeline */

.timeline{
max-width:900px;
margin:auto;
}

.item{
background:white;
padding:25px;
margin:20px 0;
border-left:7px solid #ff7aa2;
border-radius:20px;
box-shadow:0 8px 20px rgba(0,0,0,.1);
}

/* Gift */

.gift{
font-size:120px;
text-align:center;
animation:bounce 2s infinite;
cursor:pointer;
}

@keyframes bounce{
50%{
transform:translateY(-18px);
}
}

footer{
padding:40px;
text-align:center;
font-size:18px;
}

/* Confetti */

.confetti{
position:fixed;
width:12px;
height:12px;
top:-10px;
animation:fall linear forwards;
}

@keyframes fall{
to{
transform:translateY(110vh) rotate(720deg);
}
}

/* Responsive */

@media(max-width:768px){

.hero h1{
font-size:48px;
}

.hero h2{
font-size:24px;
}

.glass{
padding:35px;
}

}

</style>
</head>

<body>

<div class="background">

<span>🎈</span>
<span>🌸</span>
<span>🎀</span>
<span>🦋</span>
<span>🌼</span>
<span>💖</span>

</div>

<section class="hero">

<div class="glass">

<h1>Happy Birthday 🎂</h1>

<h2>To My Favourite Person 💖</h2>

<p>

Today is all about celebrating your beautiful smile,
your kind heart,
and every little thing that makes you amazing.

May your life always be filled with happiness,
love,
laughter,
and endless adventures.

✨ Happy Birthday! ✨

</p>

<button onclick="celebrate()">
Celebrate 🎉
</button>

</div>

</section>

<section>

<h2 class="title">Why You're Special 🌷</h2>

<div class="cards">

<div class="card">
<div class="icon">😊</div>
<h3>Beautiful Smile</h3>
<p>Your smile lights up every room and spreads happiness wherever you go.</p>
</div>

<div class="card">
<div class="icon">💖</div>
<h3>Kind Heart</h3>
<p>You always care for everyone and make the world a little brighter.</p>
</div>

<div class="card">
<div class="icon">🌸</div>
<h3>Wonderful Soul</h3>
<p>You inspire everyone around you with positivity and kindness.</p>
</div>

</div>

</section>

<section>

<h2 class="title">Birthday Wishes ✨</h2>

<div class="timeline">

<div class="item">
🎂 May every dream you have come true.
</div>

<div class="item">
🌈 May happiness stay with you forever.
</div>

<div class="item">
🎁 May your life be full of beautiful surprises.
</div>

<div class="item">
💐 May every day be as wonderful as today.
</div>

</div>

</section>

<section>

<h2 class="title">Open Your Gift 🎁</h2>

<div class="gift" onclick="gift()">
🎁
</div>

</section>

<footer>

Made with ❤️ and lots of Birthday Wishes 🌸

</footer>

<script>

function celebrate(){

for(let i=0;i<220;i++){

let c=document.createElement("div");

c.className="confetti";

c.style.left=Math.random()*100+"vw";

c.style.background=
["#ff9aa2","#ffdac1","#e2f0cb","#b5ead7","#c7ceea","#ffc8dd"][Math.floor(Math.random()*6)];

c.style.animationDuration=(Math.random()*3+2)+"s";

document.body.appendChild(c);

setTimeout(()=>{
c.remove();
},5000);

}

}

function gift(){

celebrate();

setTimeout(()=>{
alert("🎂 Happy Birthday!\n\nMay your smile never fade,\nMay your dreams always shine,\nAnd may every moment bring you happiness! ❤️");
},300);

}

</script>

</body>
</html>